            BorderSizePixel = 0,
            Active = true
        })

        function Slider:Get() return Slider.Value end

        function Slider:Set(Value)
            if Value ~= Value then Value = Slider.Min end -- NaN check
            Slider.Value = MathClamp(Library:Round(Value, Slider.Decimals), Slider.Min, Slider.Max)
            Library.Flags[Slider.Flag] = Slider.Value
            local Percent = (Slider.Value - Slider.Min) / (Slider.Max - Slider.Min)
            if Percent ~= Percent then Percent = 0 end -- NaN check
            Items["Accent"]:Tween(TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2New(Percent, 0, 1, 0)})
            Items["Value"].Instance.Text = StringFormat("%s%s", tostring(Slider.Value), Slider.Suffix)
            if Slider.Callback then Library:SafeCall(Slider.Callback, Slider.Value) end
        end

        function Slider:SetVisibility(Bool) Items["Slider"].Instance.Visible = Bool end

        local function UpdateSlider(Input)
            local SizeX = (Input.Position.X - Items["RealSlider"].Instance.AbsolutePosition.X) / Items["RealSlider"].Instance.AbsoluteSize.X
            local Value = ((Slider.Max - Slider.Min) * SizeX) + Slider.Min
            Slider:Set(MathClamp(Library:Round(Value, Slider.Decimals), Slider.Min, Slider.Max))
        end

        -- Mobile + Desktop touch handlers
        local function StartSliding(Input)
            Slider.Sliding = true
            UpdateSlider(Input)
        end

        Items["Drag"]:Connect("InputBegan", function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                StartSliding(Input)
            end
        end)

        Items["TouchArea"]:Connect("InputBegan", function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                StartSliding(Input)
            end
        end)

        Items["RealSlider"]:Connect("InputBegan", function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                StartSliding(Input)
            end
        end)

        Library:Connect(UserInputService.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Slider.Sliding = false
            end
        end)

        Library:Connect(UserInputService.InputChanged, function(Input)
            if (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) and Slider.Sliding then
                UpdateSlider(Input)
            end
        end)

        TableInsert(Slider.Page.SearchItems, { Name = Slider.Name, Element = Items["Text"], Section = Slider.Section })
        if Slider.Default then Slider:Set(Slider.Default) end
        Library.SetFlags[Slider.Flag] = function(Value) Slider:Set(Value) end
        return Slider
    end

